TRANSLATION_PROVIDER=azure
ENABLE_PROVIDER_FALLBACK=false
FALLBACK_PROVIDERS=

AZURE_TRANSLATE_ENABLED=true
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=brazilsouth
AZURE_SOURCE_LANG=en
AZURE_TARGET_LANG=pt-br
AZURE_START_LINES_PER_BATCH=100
AZURE_MAX_LINES_PER_BATCH=100
AZURE_MIN_LINES_PER_BATCH=1
AZURE_START_CHARS_PER_BATCH=8000
AZURE_MAX_CHARS_PER_BATCH=12000
AZURE_MIN_CHARS_PER_BATCH=500
AZURE_DYNAMIC_BATCHING=true
AZURE_GROW_AFTER_SUCCESSFUL_BATCHES=10
AZURE_BATCH_GROWTH_FACTOR=1.25
AZURE_BATCH_SHRINK_FACTOR=0.5
AZURE_MAX_RETRIES=8
AZURE_INITIAL_BACKOFF_SECONDS=3
AZURE_MAX_BACKOFF_SECONDS=120
AZURE_DELAY_BETWEEN_BATCHES_SECONDS=0.1
AZURE_DYNAMIC_THROTTLE=true

# Legado/opcional (não padrão)
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com
DEEPL_SOURCE_LANG=EN
DEEPL_TARGET_LANG=PT-BR
